# ===== 私人 AI 电台 · 环境变量模板 =====
# 复制为 .env 后填入你自己的密钥（.env 已被 .gitignore，不会进 git）。
# 所有外部能力都是「自带钥匙」(Bring Your Own Keys)：用你自己的账号。

# --- LLM（DJ 大脑：选歌 + 写口播）---
# platform.deepseek.com 注册 → 创建 API Key
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- DJ 主音色 TTS：火山引擎豆包语音合成 ---
# console.volcengine.com 开通「豆包语音合成」，控制台试听后选定音色
# 鉴权为三头：App-Key(App ID) + Access-Key(Token) + Resource-Id
VOLCENGINE_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_RESOURCE_ID=
VOLCENGINE_TTS_VOICE_TYPE=
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000

# --- 来电者音色 TTS（可与 DJ 同应用，建议换个音色拉开差距）---
CALLER_TTS_APP_ID=
CALLER_TTS_ACCESS_TOKEN=
CALLER_TTS_RESOURCE_ID=
CALLER_TTS_VOICE_TYPE=

# --- ASR 语音点歌：火山引擎流式语音识别（与 TTS 同密钥体系）---
VOLCENGINE_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
VOLCENGINE_ASR_APP_ID=
VOLCENGINE_ASR_ACCESS_TOKEN=
VOLCENGINE_ASR_RESOURCE_ID=

# --- 音乐源（网易云本地 sidecar）---
MUSIC_PROVIDER=auto
NETEASE_API_BASE=http://127.0.0.1:3000

# --- F10 天气感知（Open-Meteo，免密钥）---
# 不填 = 天气功能关闭，DJ 不提天气。坐标可在地图上右键取。
WEATHER_LAT=
WEATHER_LON=
WEATHER_CITY=

# --- F9 日程感知（可选，需本机日历 CLI；不填 = 关闭）---
# 作者用的是飞书 lark-cli；你可替换成自己的日历方案，思路不变。
LARK_CLI_BIN=

# --- F12 周报飞书推送（可选；不填 = 不推送，周报仍可在网页查看）---
# 你飞书的 open_id（ou_xxx），用于把品味周报私信给自己。
LARK_NOTIFY_USER_ID=
